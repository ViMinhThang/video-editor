{
  "name": "video-editor-workspace",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "server": "npm -w backend run dev",
    "client": "npm -w frontend run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test": "npm -w backend run test",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
